# REROUTE Configuration for {{ cookiecutter.project_name }}
# Generated by REROUTE
#
# After setting up this file, install dependencies:
#   {{ cookiecutter.package_manager }} sync

# Application Settings
REROUTE_DEBUG=False
REROUTE_HOST={{ cookiecutter.host }}
REROUTE_PORT={{ cookiecutter.port }}
{% if cookiecutter.database != 'none' %}

# Database Configuration
REROUTE_DATABASE_URL=
{% if cookiecutter.database == 'postgresql' %}# Format: postgresql://user:password@localhost:5432/{{ cookiecutter.project_name }}
{% elif cookiecutter.database == 'mysql' %}# Format: mysql+pymysql://user:password@localhost:3306/{{ cookiecutter.project_name }}
{% elif cookiecutter.database == 'mongodb' %}# Format: mongodb://localhost:27017/{{ cookiecutter.project_name }}
{% elif cookiecutter.database == 'sqlite' %}# Format: sqlite:///./{{ cookiecutter.project_name }}.db
{% endif %}

# SECURITY: Never commit real credentials to version control
# Use environment variables for production
{% endif %}

# Security (Generate a new secret for production!)
REROUTE_SECRET_KEY=your-secret-key-change-in-production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# CORS Settings
# SECURITY: Default origins are restrictive. Add your domains for production.
REROUTE_ENABLE_CORS=True
REROUTE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
# For production:
#   REROUTE_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
